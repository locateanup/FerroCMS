# Copy to .env.local. Points the site at your running FerroCMS API —
# the Node runtime (pnpm --filter @ferrocms/api start:node) or a deployed
# Cloudflare Worker both work.
NEXT_PUBLIC_FERROCMS_URL="http://localhost:8787"

# Optional: used to build absolute canonical URLs in generateMetadata.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
