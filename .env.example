# ---------------------------------------------------------------------------
# FerroCMS environment variables
# Copy this file to .dev.vars (for `wrangler dev`) and fill in the values.
# Never commit real secrets — .dev.vars and .env are gitignored.
# ---------------------------------------------------------------------------

# Turso (libSQL) database URL + auth token. Create a free DB with the Turso CLI:
#   turso db create ferrocms && turso db show ferrocms --url
#   turso db tokens create ferrocms
# For local dev without an account, run `turso dev` and use http://127.0.0.1:8080.
DATABASE_URL="libsql://your-db.turso.io"
DATABASE_AUTH_TOKEN="your-turso-auth-token"

# Secret used to sign session cookies / tokens. Generate with:
#   openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Public base URL of the deployed admin (used for CORS + cookie domain).
ADMIN_ORIGIN="http://localhost:5173"

# Optional: comma-separated extra origins allowed to call the API.
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Public base URL of your front-end site (used for sitemap.xml + canonical URLs).
SITE_URL="http://localhost:3000"

# Optional: comma-separated webhook URLs notified on content changes
# (e.g. your site's deploy/revalidation hook). WEBHOOK_SECRET signs the payload.
WEBHOOK_URLS=""
WEBHOOK_SECRET=""

# Optional: Slack/Discord incoming webhook URLs and/or an email address,
# notified on publish, new comments awaiting moderation, and review requests.
# All optional — nothing is sent if none are set. Email just logs to the
# console by default (no email API key is wired up); implement EmailProvider
# (src/lib/email.ts) to send for real.
SLACK_WEBHOOK_URL=""
DISCORD_WEBHOOK_URL=""
NOTIFY_EMAIL_TO=""

# --- Node runtime only (self-host anywhere; ignored on Cloudflare Workers) ---
# Port for the Node server (default 8787).
PORT="8787"
# Directory for filesystem media storage when running on Node.
MEDIA_DIR="./.ferrocms/media"
